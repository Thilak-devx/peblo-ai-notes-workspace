# PORT: Express server port used by the backend API.
PORT=5000

# MONGO_URI: MongoDB connection string for the backend database.
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/peblo-ai-notes-workspace

# JWT_SECRET: Secret key used to sign and verify authentication tokens.
JWT_SECRET=replace-with-a-long-random-secret-value

# GEMINI_API_KEY: API key used for future Gemini integrations on the server only.
GEMINI_API_KEY=replace-with-your-gemini-api-key

# CLIENT_URL: Comma-separated frontend origins allowed to access the backend via CORS.
CLIENT_URL=http://localhost:3000,https://peblo-ai-notes-workspace-client.vercel.app

# NODE_ENV: Runtime mode used for security-sensitive defaults and logging behavior.
NODE_ENV=development
